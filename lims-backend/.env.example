# ===== LIMS Backend (M7) — biến môi trường =====
# Copy file này thành .env và chỉnh giá trị thật. KHÔNG commit .env.

# --- App ---
APP_NAME=LIMS Backend (M7 Platform)
ENVIRONMENT=development            # development | staging | production
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# --- Database (trong docker-compose, host = 'postgres') ---
DATABASE_URL=postgresql+psycopg2://lims:lims@postgres:5432/lims
DB_ECHO=false

# --- Redis (host = 'redis' trong docker-compose) ---
REDIS_URL=redis://redis:6379/0

# --- JWT (BẮT BUỘC đổi secret production, >= 32 ký tự) ---
JWT_SECRET=CHANGE_ME_super_secret_key_at_least_32_characters_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30        # <= 60 (NFR-SEC-003)
REFRESH_TOKEN_TTL_DAYS=30          # <= 30

# --- Auth lockout ---
LOGIN_MAX_FAILED=5
LOGIN_LOCKOUT_MINUTES=15

# --- MinIO / S3 (host = 'minio' trong docker-compose) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000   # endpoint FE truy cập presigned URL
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lims-attachments
MINIO_SECURE=false
PRESIGNED_URL_TTL_SECONDS=900

# --- File upload ---
MAX_UPLOAD_SIZE_BYTES=20971520     # 20MB

# --- CORS (origin frontend, phân tách dấu phẩy) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3050

# --- Seed admin (CHỈ khởi tạo — ép đổi mật khẩu lần đầu) ---
SEED_ADMIN_EMAIL=admin@lims.local
SEED_ADMIN_PASSWORD=ChangeMe@123
